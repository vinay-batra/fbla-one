# FBLA One — environment variables
# Copy to .env.local and fill in with real values from your Supabase project.
# .env.local is gitignored.

# Supabase (auth + database)
# Create a project at https://supabase.com, then copy the project URL + anon key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only Supabase key (for admin tasks, never expose to client).
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Anthropic API key (server-only, used by future AI features like study help)
# ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY
